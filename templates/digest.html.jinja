<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Digest — {{ date_display }}</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f4;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">

  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f4;">
    <tr>
      <td align="center" style="padding:24px 12px;">

        <!-- Container -->
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:8px;overflow:hidden;">

          <!-- Header -->
          <tr>
            <td style="background-color:#1a1a2e;padding:28px 32px;">
              <p style="margin:0;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#8888aa;">Daily Briefing</p>
              <h1 style="margin:6px 0 0;font-size:22px;font-weight:700;color:#ffffff;">{{ date_display }}</h1>
            </td>
          </tr>

          {% if intro %}
          <!-- Intro / Editor's note -->
          <tr>
            <td style="padding:24px 32px 8px;border-bottom:1px solid #eeeeee;">
              <p style="margin:0;font-size:15px;line-height:1.6;color:#333333;font-style:italic;">{{ intro }}</p>
            </td>
          </tr>
          {% endif %}

          <!-- Stories -->
          {% for story in stories %}
          <tr>
            <td style="padding:20px 32px {% if not loop.last %}0{% else %}20px{% endif %};">

              <!-- Category badge + source -->
              <table role="presentation" cellpadding="0" cellspacing="0" style="margin-bottom:6px;">
                <tr>
                  <td>
                    <span style="display:inline-block;padding:2px 8px;border-radius:3px;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
                      {% if story.category == 'tech' %}background-color:#e8f4fd;color:#1a73e8;
                      {% elif story.category == 'india' %}background-color:#fce8e6;color:#c5221f;
                      {% elif story.category == 'business' %}background-color:#e6f4ea;color:#137333;
                      {% elif story.category == 'geopolitics' %}background-color:#fef7e0;color:#b06000;
                      {% else %}background-color:#f1f3f4;color:#5f6368;
                      {% endif %}">{{ story.category }}</span>
                    <span style="margin-left:8px;font-size:11px;color:#888888;">{{ story.source }}</span>
                  </td>
                </tr>
              </table>

              <!-- Headline -->
              <h2 style="margin:0 0 8px;font-size:17px;font-weight:700;line-height:1.3;">
                <a href="{{ story.url }}" style="color:#1a1a2e;text-decoration:none;">{{ story.title }}</a>
              </h2>

              <!-- Summary -->
              <p style="margin:0 0 10px;font-size:14px;line-height:1.65;color:#444444;">{{ story.summary }}</p>

              <!-- Also covered -->
              {% if story.also_covered %}
              <p style="margin:0 0 10px;font-size:12px;color:#888888;font-style:italic;">
                Also covered: {{ story.also_covered | join(' &mdash; ') }}
              </p>
              {% endif %}

              <!-- Feedback links -->
              <table role="presentation" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <a href="{{ tracker_base }}/signal?id={{ story.id }}&v=useful&date={{ date_str }}&user={{ user_id }}"
                       style="display:inline-block;padding:4px 12px;margin-right:6px;border-radius:4px;font-size:12px;font-weight:600;background-color:#e8f5e9;color:#2e7d32;text-decoration:none;">
                      Useful
                    </a>
                    <a href="{{ tracker_base }}/signal?id={{ story.id }}&v=skip&date={{ date_str }}&user={{ user_id }}"
                       style="display:inline-block;padding:4px 12px;border-radius:4px;font-size:12px;font-weight:600;background-color:#fce4ec;color:#c62828;text-decoration:none;">
                      Skip
                    </a>
                  </td>
                </tr>
              </table>

              {% if not loop.last %}
              <!-- Divider -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:20px;">
                <tr><td style="border-bottom:1px solid #eeeeee;"></td></tr>
              </table>
              {% endif %}

            </td>
          </tr>
          {% endfor %}

          <!-- Footer -->
          <tr>
            <td style="background-color:#f8f9fa;padding:20px 32px;border-top:1px solid #eeeeee;">
              <p style="margin:0;font-size:12px;color:#888888;line-height:1.6;">
                You're receiving this because you set it up.
                &nbsp;·&nbsp;
                <a href="https://github.com/your-username/news-digest/blob/main/data/interest-profile.md"
                   style="color:#555555;">Update my preferences</a>
              </p>
            </td>
          </tr>

        </table>
        <!-- /Container -->

      </td>
    </tr>
  </table>
  <!-- /Wrapper -->

</body>
</html>
