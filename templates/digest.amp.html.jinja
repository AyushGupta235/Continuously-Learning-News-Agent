<!doctype html>
<html ⚡4email lang="en">
<head>
  <meta charset="UTF-8">
  <script async src="https://cdn.ampproject.org/v0.js"></script>
  <script async custom-element="amp-form" src="https://cdn.ampproject.org/v0/amp-form-0.1.js"></script>
  <script async custom-template="amp-mustache" src="https://cdn.ampproject.org/v0/amp-mustache-0.2.js"></script>
  <style amp4email-boilerplate>body{visibility:hidden}</style>
  <style amp-custom>
    body {
      margin: 0;
      padding: 0;
      background-color: #f4f4f4;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }
    .wrapper { padding: 24px 12px; background-color: #f4f4f4; }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-color: #ffffff;
      border-radius: 8px;
      overflow: hidden;
    }
    .header { background-color: #1a1a2e; padding: 28px 32px; }
    .header-label {
      margin: 0;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #8888aa;
    }
    .header-date { margin: 6px 0 0; font-size: 22px; font-weight: 700; color: #ffffff; }
    .intro { padding: 24px 32px 8px; border-bottom: 1px solid #eeeeee; }
    .intro p { margin: 0; font-size: 15px; line-height: 1.6; color: #333333; font-style: italic; }
    .story { padding: 20px 32px; }
    .story-divider { border: none; border-top: 1px solid #eeeeee; margin: 20px 0 0; }
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 3px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .badge-tech    { background-color: #e8f4fd; color: #1a73e8; }
    .badge-india   { background-color: #fce8e6; color: #c5221f; }
    .badge-business { background-color: #e6f4ea; color: #137333; }
    .badge-geopolitics { background-color: #fef7e0; color: #b06000; }
    .badge-other   { background-color: #f1f3f4; color: #5f6368; }
    .source { margin-left: 8px; font-size: 11px; color: #888888; }
    .story-title { margin: 6px 0 8px; font-size: 17px; font-weight: 700; line-height: 1.3; }
    .story-title a { color: #1a1a2e; text-decoration: none; }
    .summary { margin: 0 0 10px; font-size: 14px; line-height: 1.65; color: #444444; }
    .also-covered { margin: 0 0 10px; font-size: 12px; color: #888888; font-style: italic; }
    /* Feedback form */
    .feedback-form { margin-top: 8px; }
    .feedback-form button {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 4px;
      font-size: 12px;
      font-weight: 600;
      border: none;
      cursor: pointer;
    }
    .btn-useful { background-color: #e8f5e9; color: #2e7d32; margin-right: 6px; }
    .btn-skip   { background-color: #fce4ec; color: #c62828; }
    .feedback-noted { font-size: 12px; color: #888888; }
    .feedback-error { font-size: 12px; color: #c62828; }
    /* Footer */
    .footer {
      background-color: #f8f9fa;
      padding: 20px 32px;
      border-top: 1px solid #eeeeee;
    }
    .footer p { margin: 0; font-size: 12px; color: #888888; line-height: 1.6; }
    .footer a { color: #555555; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="container">

      <!-- Header -->
      <div class="header">
        <p class="header-label">Daily Briefing</p>
        <h1 class="header-date">{{ date_display }}</h1>
      </div>

      {% if intro %}
      <!-- Intro -->
      <div class="intro">
        <p>{{ intro }}</p>
      </div>
      {% endif %}

      <!-- Stories -->
      {% for story in stories %}
      <div class="story">

        <!-- Badge + source -->
        <div>
          <span class="badge badge-{% if story.category in ['tech','india','business','geopolitics'] %}{{ story.category }}{% else %}other{% endif %}">{{ story.category }}</span>
          <span class="source">{{ story.source }}</span>
        </div>

        <!-- Headline -->
        <h2 class="story-title">
          <a href="{{ story.url }}">{{ story.title }}</a>
        </h2>

        <!-- Summary -->
        <p class="summary">{{ story.summary }}</p>

        <!-- Also covered -->
        {% if story.also_covered %}
        <p class="also-covered">Also covered: {{ story.also_covered | join(' — ') }}</p>
        {% endif %}

        <!-- Feedback form (AMP) -->
        <form class="feedback-form"
              method="post"
              action-xhr="{{ tracker_base }}/signal"
              target="_top">
          <input type="hidden" name="id"   value="{{ story.id }}">
          <input type="hidden" name="date" value="{{ date_str }}">
          <input type="hidden" name="user" value="{{ user_id }}">

          <div submitting>
            <button class="btn-useful" type="submit" name="v" value="useful">Useful</button>
            <button class="btn-skip"   type="submit" name="v" value="skip">Skip</button>
          </div>

          <div submit-success>
            <template type="amp-mustache">
              <span class="feedback-noted">✓ Noted</span>
            </template>
          </div>

          <div submit-error>
            <template type="amp-mustache">
              <span class="feedback-error">⚠ Could not record — try again</span>
            </template>
          </div>
        </form>

        {% if not loop.last %}<hr class="story-divider">{% endif %}
      </div>
      {% endfor %}

      <!-- Footer -->
      <div class="footer">
        <p>
          You're receiving this because you set it up.
          &nbsp;·&nbsp;
          <a href="https://github.com/your-username/news-digest/blob/main/data/interest-profile.md">Update my preferences</a>
        </p>
      </div>

    </div>
  </div>
</body>
</html>
